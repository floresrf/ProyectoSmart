<?xml version="1.0" encoding="utf-8"?>

  <LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#254445"
    android:gravity="center"
    android:padding="12dp">

    <!-- Indicador de Alarma / Alerta de Pastilla -->
    <TextView
      android:id="@+id/tvHoraAlarmaReloj"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="07:30 AM"
      android:textColor="#BFA067"
      android:textSize="18sp"
      android:textStyle="bold"
      android:letterSpacing="0.02" />

    <!-- Nombre del Medicamento / Paciente Corto -->
    <TextView
      android:id="@+id/tvMedicamentoReloj"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:text="Paracetamol - 500mg"
      android:textAlignment="center"
      android:textColor="#FFFFFF"
      android:textSize="12sp"
      android:alpha="0.9"
      android:ellipsize="end"
      android:maxLines="1"
      android:layout_marginTop="2dp"
      android:layout_marginBottom="12dp" />

    <!-- Botón Principal de Dispensado Rápido (Estilo Circular para Reloj) -->
    <com.google.android.material.button.MaterialButton
      android:id="@+id/btnDispensarReloj"
      android:layout_width="96dp"
      android:layout_height="96dp"
      android:backgroundTint="#BFA067"
      android:text="DISPENSAR\nAHORA"
      android:textSize="11sp"
      android:textStyle="bold"
      android:textColor="#FFFFFF"
      android:insetTop="0dp"
      android:insetBottom="0dp"
      android:gravity="center"
      android:lineSpacingMultiplier="0.9"
      app:cornerRadius="48dp"
      app:iconGravity="top"
      app:rippleColor="#4DFFFFFF" />

    <!-- Recordatorio Pequeño Inferior -->
    <TextView
      android:id="@+id/tvStatusReloj"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="Alarma Activa"
      android:textColor="#FFFFFF"
      android:textSize="10sp"
      android:alpha="0.6"
      android:layout_marginTop="8dp" />

  </LinearLayout>
