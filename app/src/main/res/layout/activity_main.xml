<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity"
    android:background="#254445">

  <LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="28dp"
    android:background="#254445"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent">

    <TextView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:text="INICIO DE SESIÓN"
      android:textAlignment="center"
      android:textSize="24sp"
      android:textStyle="bold"
      android:textColor="@color/white"
      android:letterSpacing="0.05"
      android:layout_marginBottom="32dp" />

    <!-- Campo: Usuario -->
    <com.google.android.material.textfield.TextInputLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginBottom="20dp"
      android:hint="Usuario"
      android:textColorHint="#B3FFFFFF"
      app:hintTextColor="@color/white"
      app:boxStrokeColor="@color/white"
      app:boxStrokeWidth="1dp"
      app:boxStrokeWidthFocused="2dp"
      app:boxCornerRadiusTopStart="8dp"
      app:boxCornerRadiusTopEnd="8dp"
      app:boxCornerRadiusBottomStart="8dp"
      app:boxCornerRadiusBottomEnd="8dp"
      style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

      <!-- Mantiene el ID oculto solicitado originalmente por si se usa en Backend,
           pero el texto visual ahora vive en el Hint dinámico de Material -->
      <TextView
        android:id="@+id/Usuario"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:text="Usuario"
        android:visibility="gone" />

      <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/ctUsuario"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="text"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Campo: Contraseña -->
    <com.google.android.material.textfield.TextInputLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginBottom="32dp"
      android:hint="Contraseña"
      android:textColorHint="#B3FFFFFF"
      app:hintTextColor="@color/white"
      app:boxStrokeColor="@color/white"
      app:boxStrokeWidth="1dp"
      app:boxStrokeWidthFocused="2dp"
      app:boxCornerRadiusTopStart="8dp"
      app:boxCornerRadiusTopEnd="8dp"
      app:boxCornerRadiusBottomStart="8dp"
      app:boxCornerRadiusBottomEnd="8dp"
      app:passwordToggleEnabled="true"
      app:passwordToggleTint="@color/white"
      style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

      <TextView
        android:id="@+id/Contraseña"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:text="Contraseña"
        android:visibility="gone" />

      <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/ctContraseña"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="textPassword"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Botón de Acceso -->
    <com.google.android.material.button.MaterialButton
      android:id="@+id/btnAcceder"
      android:layout_width="match_parent"
      android:layout_height="54dp"
      android:text="ACCEDER"
      android:textSize="16sp"
      android:textStyle="bold"
      android:textColor="@color/white"
      android:backgroundTint="#BFA067"
      android:letterSpacing="0.08"
      app:cornerRadius="8dp"
      app:rippleColor="#4DFFFFFF" />

  </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
