<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Principal"
    android:background="#254445"
  >

  <androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#254445">

    <!-- TabLayout Profesional con fondo oscuro y acentos dorados -->
    <com.google.android.material.tabs.TabLayout
      android:id="@+id/tabLayout"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:background="#1E3738"
      app:tabIndicatorColor="#BFA067"
      app:tabIndicatorHeight="3dp"
      app:tabSelectedTextColor="#BFA067"
      app:tabTextColor="#B3FFFFFF"
      android:elevation="4dp"
      app:layout_constraintTop_toTopOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintEnd_toEndOf="parent" />

    <!-- ViewPager2 para los fragmentos de tus catálogos/listas -->
    <androidx.viewpager2.widget.ViewPager2
      android:id="@+id/viewPager"
      android:layout_width="match_parent"
      android:layout_height="0dp"
      android:background="#254445"
      android:layout_marginBottom="16dp"
      app:layout_constraintTop_toBottomOf="@id/tabLayout"
      app:layout_constraintBottom_toTopOf="@id/btnRegresar"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintEnd_toEndOf="parent" />

    <!-- Botón de Salida Estilizado -->
    <com.google.android.material.button.MaterialButton
      android:id="@+id/btnRegresar"
      android:layout_width="wrap_content"
      android:layout_height="50dp"
      android:text="SALIR"
      android:textSize="15sp"
      android:textStyle="bold"
      android:textColor="@color/white"
      android:backgroundTint="#BFA067"
      android:letterSpacing="0.06"
      android:paddingHorizontal="32dp"
      android:layout_marginBottom="20dp"
      app:cornerRadius="8dp"
      app:rippleColor="#4DFFFFFF"
      app:layout_constraintBottom_toBottomOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintEnd_toEndOf="parent"/>

  </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
